# ============================================================
#  Mushroom Guardian Bot — Environment Variables Reference
#  คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริงก่อน deploy
#  (ไม่ต้อง commit .env เข้า Git เด็ดขาด)
# ============================================================

# ─── Discord Bot ─────────────────────────────────────────────
# Token จาก Discord Developer Portal > Bot > Token
DISCORD_TOKEN=your_discord_bot_token_here

# ─── Database ────────────────────────────────────────────────
# PostgreSQL connection string
# Railway/Render จะสร้างให้อัตโนมัติเมื่อเพิ่ม PostgreSQL service
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Express Session ─────────────────────────────────────────
# สุ่มได้จาก: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your_random_secret_here_at_least_32_chars

# ─── Server Port ─────────────────────────────────────────────
# Railway/Render จะกำหนดให้อัตโนมัติ ไม่ต้องตั้งเอง
PORT=8080

# ─── Node Environment ────────────────────────────────────────
NODE_ENV=production
